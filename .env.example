# ── Polymarket API credentials (live mode only) ──────────────────
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_BASE_URL=https://clob.polymarket.com
POLY_GAMMA_URL=https://gamma-api.polymarket.com

# ── Wallet (private key required only for live mode + balance auto-detect) ──
PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Live venue safety gates (fail closed) ────────────────────────
VENUE=paper_only
OPERATOR_COUNTRY=
POLYMOMENTUM_VENUE_COMPLIANCE_OK=0
POLYMARKET_US_API_ENABLED=0
CLOB_V2_READY=0
POLYMOMENTUM_LIVE_RECONCILIATION_READY=0
CANDLE_SETTLEMENT_ALIGNMENT_READY=false

# ── Capital & risk ────────────────────────────────────────────────
# 0 = auto-detect from wallet USDC.e balance
BANKROLL_USD=0
MAX_TOTAL_EXPOSURE_USD=80.0
MAX_POSITION_PER_MARKET_USD=20.0

# ── Candle strategy ───────────────────────────────────────────────
CANDLE_POSITION_PCT=0.10
CANDLE_MIN_PRICE=0.10
CANDLE_MAX_PRICE=0.90
CANDLE_EDGE_CAP=0.25
CANDLE_SKIP_DEAD_ZONE=true
CANDLE_DEAD_ZONE_LO=0.80
CANDLE_DEAD_ZONE_HI=0.90
CANDLE_MIN_EV_BUFFER=0.05

# ── Runtime safety floors for promoted artifacts (tighten only) ──
CANDLE_RUNTIME_MIN_CONFIDENCE_FLOOR=0.0
CANDLE_RUNTIME_MIN_Z_FLOOR=0.0
CANDLE_RUNTIME_MIN_EDGE_FLOOR=0.0
CANDLE_RUNTIME_MIN_EV_BUFFER_FLOOR=-1.0
CANDLE_RUNTIME_MIN_PRICE_FLOOR=0.0
CANDLE_RUNTIME_MAX_PRICE_CEILING=1.0
CANDLE_MICROSTRUCTURE_MAX_SPREAD=1.0
CANDLE_MICROSTRUCTURE_MIN_BOOK_DEPTH=0.0
CANDLE_MICROSTRUCTURE_MIN_BOOK_PRESSURE=-1.0

# ── Candle zone gates (early / primary / late / terminal) ────────
CANDLE_ZONE_EARLY_MIN_CONFIDENCE=0.55
CANDLE_ZONE_EARLY_MIN_Z=2.0
CANDLE_ZONE_EARLY_MIN_EDGE=0.03
CANDLE_ZONE_PRIMARY_MIN_Z=1.0
CANDLE_ZONE_LATE_MIN_CONFIDENCE=0.65
CANDLE_ZONE_LATE_MIN_Z=0.5
CANDLE_ZONE_LATE_MIN_EDGE=0.08
CANDLE_ZONE_TERMINAL_MIN_CONFIDENCE=0.55
CANDLE_ZONE_TERMINAL_MIN_Z=0.3
CANDLE_ZONE_TERMINAL_MIN_EDGE=0.03
CANDLE_NOISE_Z_THRESHOLD=0.3

# ── Volatility regime sizing (HIGH / EXTREME multipliers) ────────
CANDLE_VOL_HIGH_MULTIPLIER=1.5
CANDLE_VOL_EXTREME_MULTIPLIER=2.0

# ── Cross-asset lead-lag (default off) ───────────────────────────
CANDLE_CROSS_ASSET_ENABLED=0
CANDLE_CROSS_ASSET_MIN_CORRELATION=0.70
CANDLE_CROSS_ASSET_CONFIDENCE_BOOST=0.10

# ── Maker fee optimization ────────────────────────────────────────
CANDLE_PREFER_MAKER=0

# ── Circuit breaker ───────────────────────────────────────────────
CANDLE_BREAKER_MIN_TRADES=20
CANDLE_BREAKER_MIN_WIN_RATE=0.65
CANDLE_BREAKER_MAX_DRAWDOWN_PCT=0.30
CANDLE_PAPER_BREAKER_RESET_ON_START=0

# ── Slack alerter (required in live mode) ────────────────────────
SLACK_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
ALERT_REQUIRED=0

# ── Operational kill switch ──────────────────────────────────────
KILL_SWITCH_PATH=/opt/polymomentum/KILL

# ── Logging ──────────────────────────────────────────────────────
RUST_LOG=info

# ── Persistence paths (override if you want non-default locations) ──
POLYMOMENTUM_DATA_DIR=/opt/polymomentum/data
POLYMOMENTUM_LOGS_DIR=/opt/polymomentum/logs
STATE_DB_PATH=/opt/polymomentum/logs/candle/state.db
SESSION_LOG_DIR=/opt/polymomentum/logs/sessions
